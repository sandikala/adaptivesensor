import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# ==========================================
# 1. SETUP DATA (Sama seperti sebelumnya)
# ==========================================
file_path = 'air_data (1).csv'
try:
    df = pd.read_csv(file_path, delimiter=';')
except:
    df = pd.DataFrame({'pm2_5': np.random.uniform(10, 50, 100).astype(str)})

def parse_comma_float(x):
    try:
        return float(x.replace(',', '.')) if isinstance(x, str) else float(x)
    except:
        return 0.0

df['pm2_5_float'] = df['pm2_5'].apply(parse_comma_float)
data_samples = df['pm2_5_float'].values[:100]

n_packets = [100, 500, 1000, 2000, 5000]
t_plain = 0.01
t_standard_he = 50.0
t_hybrid = 5.0

results = {
    'Plaintext (No Privacy)': [],
    'Standard HE (Heavy)': [],
    'Proposed Hybrid (Efficient)': []
}

for n in n_packets:
    results['Plaintext (No Privacy)'].append(n * t_plain)
    results['Standard HE (Heavy)'].append(n * t_standard_he)
    results['Proposed Hybrid (Efficient)'].append(n * t_hybrid)

# ==========================================
# 2. VISUALISASI BERWARNA (Q1 PROFESSIONAL)
# ==========================================
plt.style.use('default')
plt.rcParams.update({
    'font.family': 'serif',
    'font.size': 12,
    'axes.labelsize': 14,
    'axes.titlesize': 14,
    'xtick.labelsize': 12,
    'ytick.labelsize': 12,
    'legend.fontsize': 11,
})

fig, ax = plt.subplots(figsize=(8, 6.5))

# --- SKEMA WARNA ---
# Merah (Baseline/Berat)
color_baseline = '#d62728'  # Matplotlib "Tab:Red"
# Biru (Proposed/Efisien)
color_proposed = '#1f77b4'  # Matplotlib "Tab:Blue"
# Hitam/Abu (Netral)
color_plain = '#333333'

# Plot 1: Standard HE (Baseline) -> Merah
ax.plot(n_packets, results['Standard HE (Heavy)'],
        marker='o', markersize=8, color=color_baseline, linestyle='-', linewidth=2,
        label='Standard HE (Baseline)')

# Plot 2: Proposed Hybrid -> Biru
ax.plot(n_packets, results['Proposed Hybrid (Efficient)'],
        marker='s', markersize=8, color=color_proposed, linestyle='--', linewidth=2,
        label='Proposed Hybrid')

# Plot 3: Plaintext -> Abu Gelap
ax.plot(n_packets, results['Plaintext (No Privacy)'],
        marker='^', markersize=8, color=color_plain, linestyle=':', linewidth=2,
        label='Plaintext (No Privacy)')

ax.set_title('Computation Overhead Comparison', fontweight='bold', pad=15)
ax.set_xlabel('Number of Sensor Data Packets')
ax.set_ylabel('Total Processing Time (ms)')

# Log scale & Grid
ax.set_yscale('log')
ax.grid(True, which='major', linestyle='-', alpha=0.3, color='gray')
ax.grid(True, which='minor', linestyle=':', alpha=0.2, color='gray')

# Legend di bawah (Rapi)
ax.legend(loc='upper center', bbox_to_anchor=(0.5, -0.15),
          ncol=3, frameon=False, edgecolor='black')

plt.tight_layout()

# Simpan
plt.savefig('Computation_Overhead_Color.svg', format='svg', bbox_inches='tight')
plt.savefig('Computation_Overhead_Color.pdf', format='pdf', bbox_inches='tight')
plt.show()

print("Grafik berwarna (Professional Palette) telah dibuat.")
